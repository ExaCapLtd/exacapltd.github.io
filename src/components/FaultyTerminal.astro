---
interface Props {
  tint?: string;
  scale?: number;
  brightness?: number;
  class?: string;
}

const { tint = '#fccd59', scale = 1, brightness = 0.4, class: className = '' } = Astro.props;

function hexToRgb(hex: string): [number, number, number] {
  const h = hex.replace('#', '');
  const num = parseInt(h, 16);
  return [((num >> 16) & 255) / 255, ((num >> 8) & 255) / 255, (num & 255) / 255];
}

const tintRgb = hexToRgb(tint);
---

<div
  class={`faulty-terminal ${className}`}
  data-scale={scale}
  data-tint-r={tintRgb[0]}
  data-tint-g={tintRgb[1]}
  data-tint-b={tintRgb[2]}
  data-brightness={brightness}
  style="position:absolute;inset:0;overflow:hidden;"
>
  <canvas style="display:block;width:100%;height:100%;"></canvas>
</div>

<script is:inline>
  var vertexSrc = [
    'attribute vec2 position;',
    'varying vec2 vUv;',
    'void main() {',
    '  vUv = position * 0.5 + 0.5;',
    '  gl_Position = vec4(position, 0.0, 1.0);',
    '}'
  ].join('\n');

  var fragmentSrc = [
    'precision mediump float;',
    'varying vec2 vUv;',
    'uniform float iTime;',
    'uniform vec3 iResolution;',
    'uniform float uScale;',
    'uniform float uBrightness;',
    'uniform vec3 uTint;',
    'uniform float uScanlineIntensity;',
    'uniform float uCurvature;',
    'uniform float uFlickerAmount;',
    'uniform float uNoiseAmp;',
    'uniform vec2 uMouse;',
    'uniform float uMouseStrength;',
    'float time;',
    'float noise(vec2 p) {',
    '  return sin(p.x * 10.0) * sin(p.y * (3.0 + sin(time * 0.09))) + 0.2;',
    '}',
    'mat2 rotate(float a) {',
    '  float c = cos(a); float s = sin(a);',
    '  return mat2(c, -s, s, c);',
    '}',
    'float fbm(vec2 p) {',
    '  p *= 1.1;',
    '  float f = 0.0;',
    '  float amp = 0.5 * uNoiseAmp;',
    '  f += amp * noise(p); p = rotate(time * 0.02) * p * 2.0; amp *= 0.4545;',
    '  f += amp * noise(p); p = rotate(time * 0.02) * p * 2.0; amp *= 0.4545;',
    '  f += amp * noise(p);',
    '  return f;',
    '}',
    'float pattern(vec2 p, out vec2 q, out vec2 r) {',
    '  q = vec2(fbm(p + 1.0), fbm(rotate(0.1 * time) * p + 1.0));',
    '  r = vec2(fbm(rotate(0.1) * q), fbm(q));',
    '  return fbm(p + r);',
    '}',
    'float digit(vec2 p) {',
    '  vec2 grid = vec2(2.0, 1.0) * 15.0;',
    '  vec2 s = floor(p * grid) / grid;',
    '  p = p * grid;',
    '  vec2 q; vec2 r;',
    '  float intensity = pattern(s * 0.1, q, r) * 1.3 - 0.03;',
    '  vec2 mouseWorld = uMouse * uScale;',
    '  float distToMouse = distance(s, mouseWorld);',
    '  float mouseInfluence = exp(-distToMouse * 8.0) * uMouseStrength * 10.0;',
    '  intensity += mouseInfluence;',
    '  float ripple = sin(distToMouse * 20.0 - iTime * 5.0) * 0.1 * mouseInfluence;',
    '  intensity += ripple;',
    '  p = fract(p);',
    '  p *= 1.5;',
    '  float px5 = p.x * 5.0;',
    '  float py5 = (1.0 - p.y) * 5.0;',
    '  float x = fract(px5);',
    '  float y = fract(py5);',
    '  float i = floor(py5) - 2.0;',
    '  float j = floor(px5) - 2.0;',
    '  float n = i * i + j * j;',
    '  float f = n * 0.0625;',
    '  float isOn = step(0.1, intensity - f);',
    '  float bright = isOn * (0.2 + y * 0.8) * (0.75 + x * 0.25);',
    '  return step(0.0, p.x) * step(p.x, 1.0) * step(0.0, p.y) * step(p.y, 1.0) * bright;',
    '}',
    'float onOff(float a, float b, float c) {',
    '  return step(c, sin(iTime + a * cos(iTime * b))) * uFlickerAmount;',
    '}',
    'float displace(vec2 look) {',
    '  float y = look.y - mod(iTime * 0.25, 1.0);',
    '  float w = 1.0 / (1.0 + 50.0 * y * y);',
    '  return sin(look.y * 20.0 + iTime) * 0.0125 * onOff(4.0, 2.0, 0.8) * (1.0 + cos(iTime * 60.0)) * w;',
    '}',
    'vec3 getColor(vec2 p) {',
    '  float bar = step(mod(p.y + time * 20.0, 1.0), 0.2) * 0.4 + 1.0;',
    '  bar *= uScanlineIntensity;',
    '  p.x += displace(p);',
    '  float middle = digit(p);',
    '  float off = 0.002;',
    '  float sum = digit(p + vec2(-off, -off)) + digit(p + vec2(0.0, -off)) + digit(p + vec2(off, -off)) +',
    '              digit(p + vec2(-off, 0.0)) + digit(p + vec2(0.0, 0.0)) + digit(p + vec2(off, 0.0)) +',
    '              digit(p + vec2(-off, off)) + digit(p + vec2(0.0, off)) + digit(p + vec2(off, off));',
    '  return vec3(0.9) * middle + sum * 0.1 * vec3(1.0) * bar;',
    '}',
    'vec2 barrel(vec2 uv) {',
    '  vec2 c = uv * 2.0 - 1.0;',
    '  float r2 = dot(c, c);',
    '  c *= 1.0 + uCurvature * r2;',
    '  return c * 0.5 + 0.5;',
    '}',
    'void main() {',
    '  time = iTime * 0.333;',
    '  vec2 uv = vUv;',
    '  if (uCurvature != 0.0) uv = barrel(uv);',
    '  vec2 p = uv * uScale;',
    '  vec3 col = getColor(p);',
    '  col *= uTint;',
    '  col *= uBrightness;',
    '  gl_FragColor = vec4(col, 1.0);',
    '}'
  ].join('\n');

  document.querySelectorAll('.faulty-terminal').forEach(function(container) {
    var canvas = container.querySelector('canvas');
    if (!canvas) return;

    var isMobile = /Mobi|Android/i.test(navigator.userAgent) || window.innerWidth < 768;
    if (isMobile) {
      canvas.style.display = 'none';
      container.style.background = 'radial-gradient(ellipse at center, rgba(252,205,89,0.08) 0%, transparent 70%)';
      return;
    }

    var gl = canvas.getContext('webgl', { alpha: true, antialias: false });
    if (!gl) return;

    var scale = parseFloat(container.dataset.scale || '1');
    var tintR = parseFloat(container.dataset.tintR || '1');
    var tintG = parseFloat(container.dataset.tintG || '1');
    var tintB = parseFloat(container.dataset.tintB || '1');
    var brightness = parseFloat(container.dataset.brightness || '0.4');

    function compile(type, src) {
      var s = gl.createShader(type);
      gl.shaderSource(s, src);
      gl.compileShader(s);
      if (!gl.getShaderParameter(s, gl.COMPILE_STATUS)) {
        console.error('Shader error:', gl.getShaderInfoLog(s));
      }
      return s;
    }

    var vs = compile(gl.VERTEX_SHADER, vertexSrc);
    var fs = compile(gl.FRAGMENT_SHADER, fragmentSrc);
    var prog = gl.createProgram();
    gl.attachShader(prog, vs);
    gl.attachShader(prog, fs);
    gl.linkProgram(prog);
    if (!gl.getProgramParameter(prog, gl.LINK_STATUS)) {
      console.error('Program link error:', gl.getProgramInfoLog(prog));
    }
    gl.useProgram(prog);

    var buf = gl.createBuffer();
    gl.bindBuffer(gl.ARRAY_BUFFER, buf);
    gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1,-1, 1,-1, -1,1, 1,1]), gl.STATIC_DRAW);

    var pos = gl.getAttribLocation(prog, 'position');
    gl.enableVertexAttribArray(pos);
    gl.vertexAttribPointer(pos, 2, gl.FLOAT, false, 0, 0);

    var uTime = gl.getUniformLocation(prog, 'iTime');
    var uRes = gl.getUniformLocation(prog, 'iResolution');
    var uScaleU = gl.getUniformLocation(prog, 'uScale');
    var uBrightnessU = gl.getUniformLocation(prog, 'uBrightness');
    var uTintU = gl.getUniformLocation(prog, 'uTint');
    var uScanline = gl.getUniformLocation(prog, 'uScanlineIntensity');
    var uCurve = gl.getUniformLocation(prog, 'uCurvature');
    var uFlicker = gl.getUniformLocation(prog, 'uFlickerAmount');
    var uNoise = gl.getUniformLocation(prog, 'uNoiseAmp');
    var uMouse = gl.getUniformLocation(prog, 'uMouse');
    var uMouseStr = gl.getUniformLocation(prog, 'uMouseStrength');

    gl.uniform1f(uScaleU, scale);
    gl.uniform1f(uBrightnessU, brightness);
    gl.uniform3f(uTintU, tintR, tintG, tintB);
    gl.uniform1f(uScanline, 0.3);
    gl.uniform1f(uCurve, 0.0);
    gl.uniform1f(uFlicker, 0.6);
    gl.uniform1f(uNoise, 0.0);
    gl.uniform1f(uMouseStr, 0.2);

    var offset = Math.random() * 100;

    function resize() {
      var w = container.offsetWidth;
      var h = container.offsetHeight;
      canvas.width = w;
      canvas.height = h;
      canvas.style.width = w + 'px';
      canvas.style.height = h + 'px';
      gl.viewport(0, 0, w, h);
      gl.uniform3f(uRes, w, h, w / h);
    }

    var ro = new ResizeObserver(resize);
    ro.observe(container);
    resize();

    var visible = true;
    var io = new IntersectionObserver(function(entries) {
      visible = entries[0].isIntersecting;
    }, { threshold: 0 });
    io.observe(container);

    var targetInterval = 1000 / 24;
    var lastFrame = 0;

    function frame(t) {
      requestAnimationFrame(frame);
      if (!visible) return;
      if (t - lastFrame < targetInterval) return;
      lastFrame = t;

      var elapsed = (t * 0.001 + offset) * 0.3;
      gl.uniform1f(uTime, elapsed);

      var mx = 0.5 + 0.35 * Math.sin(elapsed * 0.4) * Math.cos(elapsed * 0.15);
      var my = 0.5 + 0.35 * Math.cos(elapsed * 0.3) * Math.sin(elapsed * 0.2);
      gl.uniform2f(uMouse, mx, my);

      gl.drawArrays(gl.TRIANGLE_STRIP, 0, 4);
    }
    requestAnimationFrame(frame);
  });
</script>
