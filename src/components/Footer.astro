---
const currentYear = new Date().getFullYear();
---

<footer class="bg-accent-500 dark:bg-accent-900 text-gray-300">
  <div class="mx-auto max-w-7xl px-6 py-16 lg:px-8">
    <div class="md:flex md:items-start md:justify-between">
      <div class="max-w-sm">
        <a href="/" class="flex items-center gap-3">
          <img src="/logos/exacap-mark.svg" alt="ExaCap" class="h-10 w-auto" />
          <span class="text-xl font-bold tracking-tight text-white">
            ExaCap
          </span>
        </a>
        <p class="mt-4 text-sm text-gray-400">
          Accelerating exceptional B2B founders with deep domain expertise. Backed by ExaDev's engineering team and track record building technology companies.
        </p>
      </div>

      <div class="mt-10 md:mt-0 grid grid-cols-2 gap-8">
        <div>
          <h3 class="text-sm font-semibold text-white">Company</h3>
          <ul class="mt-4 space-y-3">
            <li><a href="/#about" class="text-sm text-gray-400 hover:text-white transition-colors">About</a></li>
            <li><a href="/#portfolio" class="text-sm text-gray-400 hover:text-white transition-colors">Portfolio</a></li>
            <li><a href="/team" class="text-sm text-gray-400 hover:text-white transition-colors">Team</a></li>
            <li><a href="/news" class="text-sm text-gray-400 hover:text-white transition-colors">News</a></li>
            <li><a href="/#network" class="text-sm text-gray-400 hover:text-white transition-colors">Network</a></li>
          </ul>
        </div>
        <div>
          <h3 class="text-sm font-semibold text-white">Legal</h3>
          <ul class="mt-4 space-y-3">
            <li><span class="text-sm text-gray-400">ExaCap Limited</span></li>
            <li><span class="text-sm text-gray-400">Company No. 16258890</span></li>
            <li><span class="text-sm text-gray-400">Registered in England &amp; Wales</span></li>
            <li><span class="text-sm text-gray-400">M-SParc, Menai Science Park</span></li>
            <li><span class="text-sm text-gray-400">Gaerwen, Anglesey, LL60 6AG</span></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="mt-12 border-t border-gray-700 pt-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <p class="text-xs text-gray-500">&copy; {currentYear} ExaCap Limited. All rights reserved.</p>
      <div class="flex gap-6">
        <a href="https://exadev.io" target="_blank" rel="noopener" class="text-xs text-gray-500 hover:text-gray-300 transition-colors">
          Powered by ExaDev
        </a>
        <a href="https://www.linkedin.com/company/exacap" target="_blank" rel="noopener" class="text-gray-500 hover:text-gray-300 transition-colors">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
      </div>
    </div>
  </div>
</footer>
