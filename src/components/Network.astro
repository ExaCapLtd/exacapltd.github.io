<section id="network" class="bg-accent-500 dark:bg-accent-900 py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="lg:grid lg:grid-cols-2 lg:gap-16">
      <div>
        <p class="text-sm font-semibold tracking-widest uppercase text-primary-400 mb-4">Network</p>
        <h2 class="text-4xl font-bold tracking-tight text-white">
          Partner with ExaCap
        </h2>
        <p class="mt-6 text-lg leading-relaxed text-gray-300">
          We work with a network of investors, advisors, and industry specialists who share our conviction in backing exceptional founders. If you're interested in what we're building, we'd like to hear from you.
        </p>

        <div class="mt-10 space-y-6">
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-8 h-8 rounded-full bg-primary-400/20 flex items-center justify-center">
              <svg class="w-4 h-4 text-primary-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            </div>
            <div>
              <h3 class="text-base font-semibold text-white">Curated Deal Flow</h3>
              <p class="text-sm text-gray-400">Every opportunity is vetted through our rigorous technical and commercial assessment.</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-8 h-8 rounded-full bg-primary-400/20 flex items-center justify-center">
              <svg class="w-4 h-4 text-primary-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            </div>
            <div>
              <h3 class="text-base font-semibold text-white">De-Risked Investments</h3>
              <p class="text-sm text-gray-400">Our embedded engineering model reduces technical risk &mdash; the #1 cause of startup failure.</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-8 h-8 rounded-full bg-primary-400/20 flex items-center justify-center">
              <svg class="w-4 h-4 text-primary-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            </div>
            <div>
              <h3 class="text-base font-semibold text-white">Quarterly Portfolio Updates</h3>
              <p class="text-sm text-gray-400">Transparent reporting on progress, milestones, and key metrics across the portfolio.</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-8 h-8 rounded-full bg-primary-400/20 flex items-center justify-center">
              <svg class="w-4 h-4 text-primary-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            </div>
            <div>
              <h3 class="text-base font-semibold text-white">Aligned Incentives</h3>
              <p class="text-sm text-gray-400">We take stakes primarily through sweat equity and joint ventures &mdash; our success is tied directly to portfolio performance.</p>
            </div>
          </div>
        </div>
      </div>

      <div class="mt-12 lg:mt-0">
        <div class="rounded-2xl bg-accent-600 dark:bg-accent-800 p-8 border border-gray-700">
          <h3 class="text-xl font-semibold text-white mb-6">Register Your Interest</h3>
          <form
            action="https://formspree.io/f/placeholder"
            method="POST"
            class="space-y-5"
          >
            <div>
              <label for="name" class="block text-sm font-medium text-gray-300 mb-1.5">Full Name</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full rounded-lg border border-gray-600 bg-accent-700 dark:bg-accent-900 px-4 py-2.5 text-sm text-white placeholder-gray-500 focus:border-primary-400 focus:ring-1 focus:ring-primary-400 focus:outline-none"
                placeholder="Jane Smith"
              />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-gray-300 mb-1.5">Email Address</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full rounded-lg border border-gray-600 bg-accent-700 dark:bg-accent-900 px-4 py-2.5 text-sm text-white placeholder-gray-500 focus:border-primary-400 focus:ring-1 focus:ring-primary-400 focus:outline-none"
                placeholder="jane@example.com"
              />
            </div>
            <div>
              <label for="linkedin" class="block text-sm font-medium text-gray-300 mb-1.5">LinkedIn Profile</label>
              <input
                type="url"
                id="linkedin"
                name="linkedin"
                class="w-full rounded-lg border border-gray-600 bg-accent-700 dark:bg-accent-900 px-4 py-2.5 text-sm text-white placeholder-gray-500 focus:border-primary-400 focus:ring-1 focus:ring-primary-400 focus:outline-none"
                placeholder="https://linkedin.com/in/..."
              />
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-gray-300 mb-1.5">Tell us about yourself</label>
              <textarea
                id="message"
                name="message"
                rows="3"
                class="w-full rounded-lg border border-gray-600 bg-accent-700 dark:bg-accent-900 px-4 py-2.5 text-sm text-white placeholder-gray-500 focus:border-primary-400 focus:ring-1 focus:ring-primary-400 focus:outline-none resize-none"
                placeholder="Your background, sectors of interest, how you'd like to get involved..."
              ></textarea>
            </div>
            <button
              type="submit"
              class="w-full rounded-lg bg-primary-400 px-4 py-3 text-sm font-semibold text-secondary-500 hover:bg-primary-500 transition-colors"
            >
              Register Interest
            </button>
            <p class="text-xs text-gray-500 text-center">
              We'll be in touch to discuss opportunities. No commitment required.
            </p>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>
