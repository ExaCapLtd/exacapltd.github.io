---
import FaultyTerminal from './FaultyTerminal.astro';
---

<section class="relative overflow-hidden bg-accent-800 min-h-[90vh] flex items-center">
  <FaultyTerminal tint="#fccd59" scale={1} brightness={0.35} />
  <div class="absolute inset-0 bg-gradient-to-r from-accent-800/90 via-accent-800/70 to-transparent"></div>
  <div class="relative mx-auto max-w-7xl px-6 py-24 sm:py-32 lg:py-40 lg:px-8 w-full">
    <div class="max-w-3xl">
      <p class="text-sm font-semibold tracking-widest uppercase text-primary-400 mb-4">
        Accelerating Exceptional Founders
      </p>
      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold tracking-tight text-white leading-tight">
        Build faster.<br />
        Build <span class="text-primary-400">smarter</span>.<br />
        Build to last.
      </h1>
      <p class="mt-8 text-xl leading-relaxed text-gray-300 max-w-2xl">
        We partner with domain experts to build deep B2B software products and run them as lean, AI-native businesses. Our 17-strong engineering team embeds directly into portfolio companies &mdash; hands-on from day one.
      </p>
      <div class="mt-10 flex flex-wrap items-center gap-4">
        <a
          href="#portfolio"
          class="rounded-lg bg-primary-400 px-6 py-3 text-base font-semibold text-secondary-500 shadow-sm hover:bg-primary-500 transition-colors"
        >
          View Portfolio
        </a>
        <a
          href="#network"
          class="rounded-lg border border-gray-500 px-6 py-3 text-base font-semibold text-gray-200 hover:bg-accent-700 transition-colors"
        >
          Join Our Network
        </a>
      </div>

      <div class="mt-16 grid grid-cols-3 gap-8 border-t border-gray-700 pt-10">
        <div>
          <p class="text-3xl font-bold text-white">3</p>
          <p class="text-sm text-gray-400 mt-1">Portfolio Companies</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-white">17</p>
          <p class="text-sm text-gray-400 mt-1">Engineers Embedded</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-white">100%</p>
          <p class="text-sm text-gray-400 mt-1">Hands-On Partnerships</p>
        </div>
      </div>
    </div>
  </div>
</section>
