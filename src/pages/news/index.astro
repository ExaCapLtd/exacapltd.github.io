---
import Layout from '../../layouts/Layout.astro';

const postFiles = import.meta.glob('../../content/news/*.md', { eager: true }) as Record<string, any>;
const posts = Object.values(postFiles).sort((a, b) =>
  new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime()
);
---

<Layout title="News — ExaCap" description="Latest updates from ExaCap and our portfolio companies.">
  <section class="bg-white dark:bg-accent-800 py-24 sm:py-32">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <div class="max-w-2xl">
        <p class="text-sm font-semibold tracking-widest uppercase text-primary-500 mb-4">News</p>
        <h1 class="text-4xl font-bold tracking-tight text-secondary-500 dark:text-white">
          Portfolio updates
        </h1>
        <p class="mt-6 text-lg text-secondary-400 dark:text-gray-300">
          The latest from ExaCap and our portfolio companies.
        </p>
      </div>

      <div class="mt-16 space-y-12">
        {posts.map((post: any) => {
          const slug = post.file.split('/').pop()?.replace('.md', '');
          const date = new Date(post.frontmatter.date).toLocaleDateString('en-GB', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          });
          return (
            <article class="group">
              <a href={`/news/${slug}`} class="block rounded-2xl bg-secondary-50 dark:bg-accent-700 p-8 border border-gray-100 dark:border-gray-700 hover:shadow-md transition-shadow">
                <div class="flex items-center gap-4 text-sm text-secondary-400 dark:text-gray-400 mb-4">
                  <time datetime={post.frontmatter.date}>{date}</time>
                  {post.frontmatter.author && (
                    <>
                      <span>&middot;</span>
                      <span>{post.frontmatter.author}</span>
                    </>
                  )}
                </div>
                <h2 class="text-xl font-semibold text-secondary-500 dark:text-white group-hover:text-primary-500 transition-colors">
                  {post.frontmatter.title}
                </h2>
                {post.frontmatter.summary && (
                  <p class="mt-3 text-secondary-400 dark:text-gray-300">{post.frontmatter.summary}</p>
                )}
                <span class="inline-flex items-center gap-1 mt-4 text-sm font-medium text-primary-500">
                  Read more
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                </span>
              </a>
            </article>
          );
        })}
      </div>
    </div>
  </section>
</Layout>
